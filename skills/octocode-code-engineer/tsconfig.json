{
  // Compiles src/**/*.ts → scripts/ (same paths). Then minify-scripts.mjs minifies *.js there.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "node",
    "strict": true,
    "esModuleInterop": true,
    "declaration": false,
    "outDir": "scripts",
    "rootDir": "src",
    "sourceMap": false,
    "skipLibCheck": true,
    "resolveJsonModule": true
  },
  "include": ["src/**/*.ts"],
  "exclude": ["node_modules", "scripts", "dist", "src/**/*.test.ts"]
}
